# =============================================================================
# WoOdoo — Environment Variables
# Copy this file to .env and fill in your values
# Run `bash scripts/generate-keys.sh` to generate SECRET_KEY and FERNET_KEY
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=woodoo
POSTGRES_PASSWORD=woodoo
POSTGRES_DB=woodoo
POSTGRES_PORT=5432

# Full async URL for SQLAlchemy (auto-assembled from above in docker-compose)
DATABASE_URL=postgresql+asyncpg://woodoo:woodoo@postgres:5432/woodoo

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Security — CHANGE THESE IN PRODUCTION
# -----------------------------------------------------------------------------
# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# Fernet encryption key for stored credentials — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# -----------------------------------------------------------------------------
# Admin Credentials
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT token expiration in minutes (default: 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Celery Workers
# -----------------------------------------------------------------------------
# Number of concurrent worker processes (default tasks queue)
CELERY_CONCURRENCY=4

# Number of concurrent image sync workers (lower = less bandwidth)
CELERY_IMAGE_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Set to: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Ports (for docker-compose port bindings)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Frontend (Next.js public env vars)
# -----------------------------------------------------------------------------
# URL of the backend API (must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time sync progress
NEXT_PUBLIC_WS_URL=ws://localhost:8000
