# =============================================================================
# WoOdoo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate SECRET_KEY and FERNET_KEY:
#   bash scripts/generate-keys.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------

# PostgreSQL superuser credentials (used by the postgres container)
POSTGRES_USER=woodoo
POSTGRES_PASSWORD=woodoo

# PostgreSQL database name
POSTGRES_DB=woodoo

# PostgreSQL host port mapping (host:container is ${POSTGRES_PORT}:5432)
POSTGRES_PORT=5432

# Full async database URL for SQLAlchemy
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# NOTE: In Docker Compose, <host> is the service name "postgres"
DATABASE_URL=postgresql+asyncpg://woodoo:woodoo@postgres:5432/woodoo

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis connection URL (used for Celery broker, caching, pub/sub)
REDIS_URL=redis://redis:6379/0

# Redis host port mapping (host:container is ${REDIS_PORT}:6379)
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Backend — Authentication & Security
# IMPORTANT: Change SECRET_KEY and ADMIN_PASSWORD in production!
# -----------------------------------------------------------------------------

# JWT signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Or run: bash scripts/generate-keys.sh
SECRET_KEY=your-secret-key-change-in-production

# Fernet encryption key for stored credentials
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or run: bash scripts/generate-keys.sh
FERNET_KEY=

# Default admin user credentials (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT access token expiration in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Celery Workers
# -----------------------------------------------------------------------------

# Number of concurrent worker processes (default tasks queue)
CELERY_CONCURRENCY=4

# Number of concurrent image sync workers (lower = less bandwidth pressure)
CELERY_IMAGE_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Ports (host port bindings for docker-compose)
# -----------------------------------------------------------------------------

# Backend (FastAPI/uvicorn) host port
BACKEND_PORT=8000

# Frontend (Next.js) host port
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Frontend (Next.js public environment variables)
# -----------------------------------------------------------------------------

# URL of the backend API (must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time sync progress
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# Webhook Secrets (optional — for WooCommerce/Odoo webhooks)
# -----------------------------------------------------------------------------

# WooCommerce webhook secret (set in WC webhook settings)
# WC_WEBHOOK_SECRET=

# Odoo webhook secret (set in Odoo webhook settings)
# ODOO_WEBHOOK_SECRET=
