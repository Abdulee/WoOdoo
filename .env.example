# Database Configuration
# PostgreSQL connection URL (async driver)
DATABASE_URL=postgresql+asyncpg://woodoo:woodoo@postgres:5432/woodoo

# Redis Configuration
# Redis connection URL for caching and Celery broker
REDIS_URL=redis://redis:6379/0

# Security Configuration
# Secret key for JWT token signing - change in production!
SECRET_KEY=your-secret-key-change-in-production

# Admin Credentials
# Default admin username
ADMIN_USERNAME=admin

# Default admin password
ADMIN_PASSWORD=changeme

# Token Configuration
# JWT access token expiration time in minutes (default: 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Environment Configuration
# Set to 'development', 'staging', or 'production'
ENVIRONMENT=development
